#!/bin/sh
#
# summary: a simple posix script for powering down your system
# repository: http://github.com/hollowillow/scripts
#
# usage: power
#
# depedencies: systemctl, exit-hyprland (optional script for log out), hyprlock (optional)

. _lib # library script with common functions and variables
case "$1" in -h|-help|--help|help) printHelp ;; esac
checkDependency "systemctl"

getOptions() {
    OPTIONS="Power Off\nReboot\nSuspend\nHibernate\n"
    command -v exit-hyprland >/dev/null && OPTIONS="$OPTIONS""Log Out\n"
    command -v hyprlock >/dev/null && OPTIONS="$OPTIONS""Lock\n"
    printf '%b' "$OPTIONS"
}

openMenu() {
    fzf --prompt 'power: '
}

main() {
    # confirm selected invocation can be removed to skip confirmation per option
    case "$(getOptions | openMenu)" in
        "Power Off") [ "$(confirmSelection)" = "Yes" ] && systemctl poweroff;;
        "Reboot") [ "$(confirmSelection)" = "Yes" ] && systemctl reboot;;
        "Suspend") [ "$(confirmSelection)" = "Yes" ] && systemctl suspend;;
        "Hiberate") [ "$(confirmSelection)" = "Yes" ] && systemctl hibernate;;
        "Log Out") [ "$(confirmSelection)" = "Yes" ] && exit-hyprland;;
        "Lock") [ "$(confirmSelection)" = "Yes" ] && hyprlock;;
    esac
}

main
